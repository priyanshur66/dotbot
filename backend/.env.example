RPC_URL=https://eth-rpc-testnet.polkadot.io/
# Recommended dedicated write RPC for deployments and contract calls that submit transactions.
RPC_WRITE_URL=https://services.polkadothub-rpc.com/testnet
RPC_WRITE_USE_LEGACY=true
# Optional explicit gas price override for legacy tx submission on Polkadot Hub TestNet.
# RPC_WRITE_GAS_PRICE_WEI=3000000000000
BACKEND_PRIVATE_KEY=0xyourprivatekey
CONVEX_URL=https://your-convex-deployment.convex.cloud
OPENROUTER_API_KEY=sk-or-your-key
# Optional OpenRouter model override; defaults to openai/gpt-4.1-mini
# OPENROUTER_MODEL=openai/gpt-4.1-mini
# Optional OpenRouter metadata headers
# OPENROUTER_SITE_URL=https://your-app.example.com
# OPENROUTER_SITE_NAME=DotAgent
PROTOCOL_TREASURY_ADDRESS=0xyourtreasuryaddress

# Leave these blank before the first deployment. Fill them with deployed addresses afterward.
EVENT_HUB_ADDRESS=
QUOTE_TOKEN_ADDRESS=
LAUNCHPAD_ADDRESS=

# Launchpad protocol defaults.
LAUNCHPAD_POOL_ALLOCATION_BPS=8000
LAUNCHPAD_SWAP_FEE_BPS=100
LAUNCHPAD_CREATOR_FEE_SHARE_BPS=5000
LAUNCHPAD_INITIAL_USDT_LIQUIDITY=50000
LAUNCHPAD_BOOTSTRAP_USDT_MULTIPLIER=1000
PORT=3000
